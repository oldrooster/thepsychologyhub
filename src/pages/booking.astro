---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';

const pages = await getCollection('pages');
const page = pages.find(p => p.slug === 'booking')!;
const { Content } = await page.render();
---

<PageLayout title={page.data.title} description="Book an appointment at The Psychology Hub, Suite 3, 21 Leslie Hills Drive, Riccarton, Christchurch.">
  <Content />
</PageLayout>
