---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';

const pages = await getCollection('pages');
const page = pages.find(p => p.slug === 'room-rental')!;
const { Content } = await page.render();
---

<PageLayout title={page.data.title} description="Professional room rental for clinicians at The Psychology Hub, Riccarton, Christchurch.">
  <Content />
</PageLayout>
