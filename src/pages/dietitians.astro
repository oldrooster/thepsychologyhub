---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';

const pages = await getCollection('pages');
const page = pages.find(p => p.slug === 'dietitians')!;
const { Content } = await page.render();
---

<PageLayout title={page.data.title} description="Registered Dietitian services at The Psychology Hub, specialising in eating disorders and nutrition support.">
  <Content />
</PageLayout>
