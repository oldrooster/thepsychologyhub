---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';

const pages = await getCollection('pages');
const page = pages.find(p => p.slug === 'therapy')!;
const { Content } = await page.render();
---

<PageLayout title={page.data.title} description="Evidence-based therapy for individuals of all ages at The Psychology Hub in Riccarton, Christchurch.">
  <Content />
</PageLayout>
