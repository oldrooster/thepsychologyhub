---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';

const pages = await getCollection('pages');
const page = pages.find(p => p.slug === 'assessment')!;
const { Content } = await page.render();
---

<PageLayout title={page.data.title} description="Psychological assessments at The Psychology Hub, including ACC mental injury assessments and neurodevelopmental assessments.">
  <Content />
</PageLayout>
