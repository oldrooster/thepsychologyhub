---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description?: string;
  heroImage?: string;
}

const { title, description, heroImage } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="static-page">
    <div class="page-hero" style={heroImage ? `--hero-image: url('${heroImage}')` : ''}>
      <div class="container">
        <h1 class="page-title">{title}</h1>
      </div>
    </div>
    <div class="page-body">
      <div class="container">
        <div class="prose page-prose">
          <slot />
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .page-hero {
    background: var(--color-warm-white);
    background-image: var(--hero-image, none);
    background-size: cover;
    background-position: center;
    padding: 4rem 0;
    position: relative;
    border-bottom: 1px solid var(--color-border-light);
  }

  .page-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(245,241,235,0.85), rgba(245,241,235,0.95));
    pointer-events: none;
  }

  .page-hero .container {
    position: relative;
    z-index: 1;
  }

  .page-title {
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--color-sage-dark);
  }

  .page-body {
    padding: 3rem 0 5rem;
  }

  .page-prose {
    max-width: 74ch;
  }

  .page-prose :global(h2) {
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-sage-dark);
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid var(--color-sage-bg);
  }

  .page-prose :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .page-prose :global(p) {
    margin-bottom: 1.1rem;
    color: var(--color-text);
    line-height: 1.75;
  }

  .page-prose :global(ul),
  .page-prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.1rem;
  }

  .page-prose :global(li) {
    margin-bottom: 0.45rem;
    line-height: 1.65;
  }

  .page-prose :global(strong) {
    font-weight: 600;
    color: var(--color-text);
  }

  .page-prose :global(a) {
    color: var(--color-sage-dark);
    text-decoration: underline;
    text-decoration-color: var(--color-sage-light);
    text-underline-offset: 3px;
  }

  .page-prose :global(a:hover) {
    color: var(--color-green-available);
  }

  @media (max-width: 640px) {
    .page-title {
      font-size: 1.75rem;
    }

    .page-hero {
      padding: 2.5rem 0;
    }

    .page-body {
      padding: 2rem 0 3rem;
    }
  }
</style>
